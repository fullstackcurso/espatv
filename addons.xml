<?xml version='1.0' encoding='UTF-8' standalone='yes'?>
<addons>
<addon id="plugin.video.espatv" name="EspaTV" version="1.1.0" provider-name="RubénSDFA1labernt">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
    <import addon="script.module.requests"/>
    <import addon="inputstream.adaptive" optional="true"/>
  </requires>
  <extension point="xbmc.python.pluginsource" library="default.py">
    <provides>video</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="es">Addon todo en uno para contenido en castellano</summary>
    <description lang="es">TDT, RTVE a la carta, búsqueda en YouTube y Dailymotion, catálogo de vídeos, radio, podcasts, reproducción de enlaces, noticias, meteorología, agenda deportiva y mucho más.</description>
    <platform>all</platform>
    <license>GPL-2.0-or-later</license>
    <website>https://github.com/espakodi</website>
    <source>https://github.com/espakodi</source>
    <assets>
      <icon>icon.png</icon>
      <fanart>fanart.jpg</fanart>
    </assets>
  </extension>
</addon>

<addon id="repository.espatv" name="EspaTV Repository" version="1.0.0" provider-name="RubénSDFA1labernt">
    <extension point="xbmc.addon.repository" name="EspaTV Repository">
        <dir>
            <info compressed="false">https://espakodi.github.io/espatv/addons.xml</info>
            <checksum>https://espakodi.github.io/espatv/addons.xml.md5</checksum>
            <datadir zip="true">https://espakodi.github.io/espatv/</datadir>
        </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="es">Repositorio de EspaTV</summary>
        <description lang="es">Repositorio oficial para instalar y actualizar el addon EspaTV.</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.png</fanart>
        </assets>
    </extension>
</addon>
</addons>
